# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLIC_KEY=your-anon-public-key

# Public site URL (used for auth redirects, email confirmations, etc.)
# Overrides auto-detection of the app URL in production deployments.
NUXT_PUBLIC_SITE_URL=https://your-app.ondigitalocean.app
